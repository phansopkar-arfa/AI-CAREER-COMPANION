MANIFEST

# PyInstaller
#  Usually these files are written by a python script, and contain the exe and PYZ
#  files. A solid rule is to exclude build/ and dist/
#  windows .exe files
*.exe
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

